<?xml version="1.0" encoding="utf-8"?>
<!-- "Device auto-switch" toggle card on the Audio Output screen.
     Drop-in twin of card_enable_detection.xml from the Channel Input
     screen — same solid surface-container-high background, no stroke,
     MaterialSwitch on the right. Controls whether
     RouteSwitchCoordinator applies bound presets on route changes;
     when off, the route monitor still tracks new devices but the
     preset stays put. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/deviceAutoSwitchCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/deviceAutoSwitchTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Device auto-switch"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/deviceAutoSwitchBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Uses selected preset for current output"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:paddingTop="4dp" />
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/deviceAutoSwitchSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
