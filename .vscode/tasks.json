      "label": "Android: Ожидать загрузки устройства",
      "detail": "Ждать, пока AVD полностью загрузится (system.boot_completed).",
      "type": "shell",
      "command": "adb wait-for-device && adb shell 'while [[ -z $(getprop sys.boot_completed) ]]; do sleep 1; done;' && echo \"✅ Устройство готово\"",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "android",
        "showReuseMessage": false,
        "clear": true
