    {
      "label": "Android: Запустить AVD (PrologyEmulator, cold boot)",
      "detail": "Холодный запуск — стирает snapshot и данные. Нужен после смены образа системы.",
      "type": "shell",
      "command": "emulator -avd PrologyEmulator -no-snapshot -wipe-data",
      "options": {
        "env": {
          "ANDROID_SDK_ROOT": "/home/mi/Android/Sdk",
          "ANDROID_HOME": "/home/mi/Android/Sdk"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "group": "android"
      },
      "group": "none",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Android: Запустить AVD (PrologyEmulator, quick boot)",
      "detail": "Быстрый запуск из сна snapshot. Повседневное использование.",
